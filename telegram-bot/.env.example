# Telegram Bot Token (required)
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# PostgreSQL connection string (required)
# Uses the same database as the main backend
DATABASE_URL=postgresql://opendex_user:password@localhost:5432/opendex

# SSL certificate verification for PostgreSQL
# Set to 'false' for Render's self-signed certs
DB_SSL_REJECT_UNAUTHORIZED=false

# OpenDex API URL (the deployed backend)
OPENDEX_API_URL=https://opendex-api-dy30.onrender.com

# Frontend URL (for "View on OpenDEX" links)
OPENDEX_FRONTEND_URL=https://opendex.online

# Webhook mode (leave empty for long-polling in dev)
# Set to your bot's public URL for production (e.g. https://opendex-telegram-bot.onrender.com)
WEBHOOK_URL=
# Port for webhook HTTP server (Render sets PORT automatically)
WEBHOOK_PORT=3000
# Secret token for webhook verification (optional but recommended)
WEBHOOK_SECRET=

# Alert polling interval in milliseconds (default: 60000 = 1 minute)
ALERT_POLL_INTERVAL_MS=60000

# Max alerts per user (default: 10)
MAX_ALERTS_PER_USER=10

# Log level: error, warn, info, debug (default: info)
LOG_LEVEL=info
